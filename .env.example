# Secrets fuer die Content-Maschine — echte Werte NIE committen.
# Lokal als .env kopieren und ausfuellen; in Phase 3 als GitHub Secrets setzen.
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# GH_REPO = Slug im Format owner/name (z.B. erriionn/insektenblitz fuer Demo, bei Uebergabe thetopseller-ops/insektenblitz)
GH_PAT=
GH_REPO=
# SITE_BASE_URL = oeffentliche Deploy-Basis-URL fuer den Vorschau-Link (Default: https://insektenblitz.com)
# Demo: eigene Netlify-Domain (z.B. https://insektenblitz-demo.netlify.app) oder Cloudflare Pages
SITE_BASE_URL=
